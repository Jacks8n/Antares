#pragma kernel UpdateParticles
#pragma kernel SetupCLL
#pragma kernel SolveConstraints

#include "HLSLSupport.cginc"

#define MAX_PARTICLE_VELOCITY 128

#define PARTICLE_FLAG_ALIVE 1

// ensure that the `val` is within [-`bound`, `bound`]
uint F32ToF16Uniform(float val, float bound)
{
    return uint(val * (32767.0 / bound)) & 0xffff;
}

// ensure that the `val` is within [0, 65535]
float F16UniformToF32(uint val, float bound)
{
    // (1.0 / 32767.0) has error around -0.000000000000524003
    const float fval = (val & 0x7fff) * (bound * (1.0 / 32767.0));
    
    return val & 0x8000 ? -fval : fval;
}

// ensure that the `val` is within [0.0, 1.0]
uint F32UNormToF16(float val)
{
    return uint(val * 65535.0);
}

// ensure that the `val` is within [0, 65535]
float F16ToF32UNorm(uint val)
{
    // (1.0 / 65535.0) has error around -0.00000000000189670
    return val * (1.0 / 65535.0);
}

struct FluidParticle
{
    uint VelocityXY;
    uint VelocityZPosX;
    uint PositionYZ;

    // higher 16 bits are reserved for future
    uint Flags;
    
    float3 GetVelocity()
    {
        return float3(F16UniformToF32(VelocityXY >> 16, MAX_PARTICLE_VELOCITY),
                      F16UniformToF32(VelocityXY & 0xffff, MAX_PARTICLE_VELOCITY),
                      F16UniformToF32(VelocityZPosX >> 16, MAX_PARTICLE_VELOCITY));
    }
    
    float3 GetPosition_UNorm()
    {
        return float3(F16ToF32UNorm(VelocityZPosX & 0xffff),
                      F16ToF32UNorm(PositionYZ >> 16),
                      F16ToF32UNorm(PositionYZ & 0xffff));
    }
    
    void Update(float3 velocity, float3 pos)
    {
        VelocityXY = (F32ToF16Uniform(velocity.x, MAX_PARTICLE_VELOCITY) << 16)
                    | F32ToF16Uniform(velocity.y, MAX_PARTICLE_VELOCITY);
        VelocityZPosX = (F32ToF16Uniform(velocity.z, MAX_PARTICLE_VELOCITY) << 16)
                       | F32UNormToF16(pos.x);
        PositionYZ = (F32UNormToF16(pos.y) << 16) | F32UNormToF16(pos.z);
    }
    
    bool IsAlive()
    {
        return Flags & 1;
    }
};

// aggregate of five float3s and one 16bit flag
struct PackedParticles
{
    // Data[0] ... Data[8]'s higher 16 bits: float3 position
    // Data[8]'s lower 16 bits: particle state flags, 3 bits per particle, grouped by flag
    // flag bits layout: { reserved[15:5], alive[4:0] }
    uint Data[8];
    
    float3 GetPosition(uint index)
    {
        const uint offset = index * 3;

        float3 pos;

        [unroll]
        for (uint i = 0; i < 3; i++)
        {
            const uint dindex = (offset + i) / 2;
            const uint doffset = (offset + i) % 2;

            const uint f16 = doffset ? Data[dindex] & 0xffff : Data[index] >> 16;
            
            pos[i] = F16ToF32UNorm(f16);
        }
        
        return pos;
    }
    
    bool IsAnyAlive()
    {
        return Data[8] & 0x1f;
    }
    
    bool IsAlive(uint index)
    {
        return Data[8] & (1 << index);
    }
};

#define CLL_EMPTY 0

CBUFFER_START(SPHParameters)
float TimeStep;

float3 CellVolumeSize;

uint FluidParticleCount;
CBUFFER_END

// first FluidParticleCount particles are sph particles which are both added to cll and solved
// rest particles are point clouds which is only added to cll
// must be aligned to 64 elements
RWStructuredBuffer<PackedParticles> PBDParticles;

// every grid is initialized to CLL_EMPTY
RWTexture3D<uint> CellVolume;

// first element is global counter, which is initialized to 2
RWBuffer<uint> CellLinkedList;

[numthreads(64, 1, 1)]
void UpdateParticles(uint3 id : SV_DispatchThreadID)
{
    // todo
}

uint3 GetCellID(float3 pos)
{
    const float3 cpos = min(CellVolumeSize * pos, CellVolumeSize - float(0.5).xxx);
    return (uint3) cpos;
}

uint AddCLLNode()
{
    uint nodeIndex;
    InterlockedAdd(CellLinkedList[0], 2, nodeIndex);
    return nodeIndex;
}

uint GetNextCLLNode(uint index)
{
    return CellLinkedList[index];
}

void SetNextCLLNode(uint index, uint next)
{
    CellLinkedList[index] = next;
}

uint GetCLLNodeValue(uint index)
{
    return CellLinkedList[index + 1];
}

void SetCLLNodeValue(uint index, uint value)
{
    CellLinkedList[index + 1] = value;
}

[numthreads(64, 1, 1)]
void SetupCLL(uint3 id : SV_DispatchThreadID)
{
    const PackedParticles particles = PBDParticles[id.x];
    
    if (!particles.IsAnyAlive())
        return;
    
    [unroll]
    for (uint i = 0; i < 5; i++)
    {
        if (!particles.IsAlive(i))
            continue;
        
        const uint pindex = id.x * 5 + i;
        const float3 pos = particles.GetPosition(i);
        const uint3 cid = GetCellID(pos);
        
        const uint nodeIndex = AddCLLNode();
        SetCLLNodeValue(nodeIndex, pindex);
        
        uint prevNodeIndex;
        InterlockedExchange(CellVolume[cid], nodeIndex, prevNodeIndex);
        SetNextCLLNode(nodeIndex, prevNodeIndex);
    }
}

