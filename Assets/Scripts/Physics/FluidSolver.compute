float3 GetParticlePosition(uint index)
{
    return PBDParticles[index / 5].GetPosition(index % 5);
}

[numthreads(64, 1, 1)]
void SolveConstraints(uint3 id : SV_DispatchThreadID)
{
    // these constraints are solved
    // 1. fluid density
    // 2. point clouds bound
    // 3. sdf bound

    const uint packIndex = id.x / 5;
    const uint particleIndex = id.x % 5;
    const PackedParticles particles = PBDParticles[packIndex];
    
    if (!particles.IsAlive(particleIndex))
        return;
    
    const float3 pos = particles.GetPosition(particleIndex);
        
    const uint3 cid = GetCellID(pos);
    uint node = CellVolume[cid];
    
    do
    {
        const uint pindex = GetCLLNodeValue(node);
        if (pindex != id.x)
        {
            if (pindex < FluidParticleCount)
            {
                // fluid density
                const float3 r = (GetParticlePosition(pindex) - pos) * ;
            
                const float3 grad = SPHKernelGradiant(r);
                const float c = SPHKernel(r);
                const float step;
            }
            else
            {
                // point cloud bound
            }
        }
        
        node = GetNextCLLNode(node);
    } while (node != CLL_EMPTY);
}
